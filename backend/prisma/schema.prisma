datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  AGENT
  CLIENT
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  name         String
  role         Role     @default(CLIENT)
  isActive     Boolean  @default(true)
  refreshToken String?  // Almacena el token de refresco hasheado para invalidar sesiones en logout
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users") // Mapea el modelo a la tabla 'users' en minúsculas en PostgreSQL
}
