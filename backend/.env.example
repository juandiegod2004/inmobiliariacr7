# Configuración de base de datos PostgreSQL
DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/inmobiliaria_db?schema=public"

# Secretos para firma de tokens JWT (Deben ser cadenas largas y aleatorias de al menos 64 caracteres en producción)
# Puedes generar uno en la terminal usando: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET="default_access_secret_de_64_caracteres_minimo_para_desarrollo_local_1234567890"
JWT_REFRESH_SECRET="default_refresh_secret_diferente_de_64_caracteres_minimo_para_desarrollo_local_1234567890"

# Tiempos de expiración de JWT
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Seguridad y Hashing
BCRYPT_ROUNDS=12

# Configuración del servidor de Express
PORT=4000
NODE_ENV="development"

# Configuración CORS (Origen permitido del frontend en React)
CORS_ORIGIN="http://localhost:3000"
